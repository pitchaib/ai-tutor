# ?????????????????????????????????????????????????????????????????????????????
# Vertex AI Gemma / Gemini endpoint — single source of truth.
#
# Copy this file to configs/vertex.env and fill in your project's values.
# start.sh automatically sources configs/vertex.env and exports these values
# to learn_api, gradio_ui and html_frontend so the endpoint can be rotated
# in ONE place (no code edits required).
#
#   cp configs/vertex.env.example configs/vertex.env
#   vim configs/vertex.env
#   ./start.sh restart
#
# configs/vertex.env is .gitignored so real endpoint IDs never leak into git.
# ?????????????????????????????????????????????????????????????????????????????

# GCP project id (human-readable) and project number (used in the PSC DNS name).
#
# Find your project number with:
#   gcloud projects describe <YOUR_PROJECT_ID> --format='value(projectNumber)'
# TODO: Replace with your GCP project ID
VERTEX_PROJECT_ID="<YOUR_PROJECT_ID>"
# TODO: Replace with your GCP project number
VERTEX_PROJECT_NUMBER="<YOUR_PROJECT_NUMBER>"

# Region and Model Garden / online-prediction endpoint id (from the Vertex AI console).
# TODO: Replace with your deployment region (e.g. us-central1, asia-southeast1)
VERTEX_LOCATION="<YOUR_REGION>"
# TODO: Replace with your numeric or named endpoint ID from the Vertex AI console
VERTEX_ENDPOINT_ID="<YOUR_ENDPOINT_ID>"

# Full console URL — code can parse project / location / endpoint_id out of this.
# Leave as-is (it references the four variables above) once those are filled in.
VERTEX_ENDPOINT_URL="https://console.cloud.google.com/vertex-ai/online-prediction/locations/${VERTEX_LOCATION}/endpoints/${VERTEX_ENDPOINT_ID}?project=${VERTEX_PROJECT_ID}"

# PSC / dedicated-endpoint FQDN.
# For a Vertex AI private (PSC) or Model Garden dedicated endpoint the hostname
# follows this pattern:
#
#   <ENDPOINT_ID>.<LOCATION>-<TENANT_PROJECT_NUMBER>.prediction.vertexai.goog
#
# NOTE: The number in the hostname is the Google-managed *tenant* project number,
# NOT your own project number (VERTEX_PROJECT_NUMBER above).
#
# For public endpoints, leave blank — the SDK will use the default
# `<location>-aiplatform.googleapis.com` host.
# TODO: Replace with your dedicated prediction host (or leave blank for public endpoint)
VERTEX_API_ENDPOINT="<YOUR_ENDPOINT_ID>.<YOUR_REGION>-<TENANT_PROJECT_NUMBER>.prediction.vertexai.goog"

# ?? TTS region override ??????????????????????????????????????????????????????
# gemini-2.5-flash-preview-tts is only published in a subset of regions.
# Pin TTS separately from the Gemma endpoint so that rotating the Gemma
# endpoint to any region does NOT break voice output.
# TODO: Replace with the region where Gemini TTS is available for your project
VERTEX_TTS_LOCATION="us-central1"
# TODO: Replace with your TTS project ID (usually same as VERTEX_PROJECT_ID)
VERTEX_TTS_PROJECT="${VERTEX_PROJECT_ID}"
